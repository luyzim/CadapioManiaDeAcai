# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3110

# Public URL used in logs, reverse proxy setup, and production documentation.
# Local dev can leave this empty and keep testing over HTTP.
PUBLIC_BASE_URL=

# Reverse proxy / HTTPS
# In local dev, false is the simplest setup.
# Behind Nginx on the same host, use loopback or 1.
TRUST_PROXY=false

# CORS
# Use * only in local development.
# In production, prefer explicit origins separated by commas.
CORS_ORIGIN=*

# Sessions and cookies
SESSION_SECRET=
SESSION_COOKIE_NAME=praticaexistencionista.sid
SESSION_COOKIE_MAX_AGE_MS=604800000
SESSION_COOKIE_SAME_SITE=lax

# In local HTTP dev, keep false.
# In production HTTPS, set true.
SESSION_COOKIE_SECURE=false

# Security headers
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=false
HSTS_MAX_AGE_SECONDS=15552000
HSTS_INCLUDE_SUBDOMAINS=true

# Database
PGHOST=
PGPORT=
PGDATABASE=
PGUSER=
PGPASSWORD=
DATABASE_URL=

# Auth
JWT_SECRET=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"
FIREBASE_WEB_API_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
