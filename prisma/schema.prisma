generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admins {
  id                   Int                    @id @default(autoincrement())
  email                String                 @unique
  pass_hash            String
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  order_status_history order_status_history[]
}

model cart {
  id         Int       @id @default(autoincrement())
  session_id String    @db.VarChar(255)
  item_id    Int
  quantity   Int       @default(1)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  items      items     @relation(fields: [item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([session_id, item_id])
  @@index([session_id], map: "idx_cart_session_id")
}

model categories {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  items items[]
}

model item_options {
  id              Int    @id @default(autoincrement())
  item_id         Int
  name            String
  value           String
  add_price_cents Int    @default(0)
  items           items  @relation(fields: [item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model items {
  id           Int            @id @default(autoincrement())
  category_id  Int
  name         String @unique
  short_desc   String?
  ingredients  String?
  price_cents  Int
  image_url    String?
  active       Boolean        @default(true)
  cart         cart[]
  item_options item_options[]
  categories   categories     @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order_items  order_items[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_items {
  id               BigInt @id @default(autoincrement())
  order_id         BigInt
  item_id          Int
  qty              Int
  unit_price_cents Int
  options          Json   @default("[]")
  items            items  @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders           orders @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model order_status_history {
  id         BigInt       @id @default(autoincrement())
  order_id   BigInt
  status     order_status
  changed_by Int?
  changed_at DateTime     @default(now()) @db.Timestamptz(6)
  admins     admins?      @relation(fields: [changed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders     orders       @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model orders {
  id                   BigInt                 @id @default(autoincrement())
  customer_name        String?
  customer_table       String?
  delivery_address     String?
  delivery_city        String?
  delivery_state       String?
  delivery_zip_code    String?
  status               order_status           @default(Recebido)
  total_cents          Int                    @default(0)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  client_id            Int?
  clients              clients?               @relation(fields: [client_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  order_items          order_items[]
  order_status_history order_status_history[]
}

enum order_status {
  Recebido
  Em_preparo @map("Em preparo")
  Pronto
  Entregue
}

model clients {
  id         Int       @id @default(autoincrement())
  name       String
  email      String    @unique
  pass_hash  String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  orders     orders[]
}
